{
  "name": "portfolioai",
  "version": "1.0.0",
  "private": true,
  "description": "AI-powered portfolio builder and career intelligence platform",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "dev:web": "turbo run dev --filter=@portfolioai/web",
    "dev:api": "turbo run dev --filter=@portfolioai/api",
    "dev:ai": "turbo run dev --filter=@portfolioai/ai-service",
    "lint": "turbo run lint",
    "type-check": "turbo run type-check",
    "test": "turbo run test",
    "test:e2e": "turbo run test:e2e",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "db:generate": "turbo run db:generate --filter=@portfolioai/database",
    "db:push": "turbo run db:push --filter=@portfolioai/database",
    "db:migrate": "turbo run db:migrate --filter=@portfolioai/database",
    "db:seed": "turbo run db:seed --filter=@portfolioai/database",
    "db:studio": "turbo run db:studio --filter=@portfolioai/database",
    "clean": "turbo run clean && rimraf node_modules",
    "prepare": "husky"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "husky": "^9.1.0",
    "lint-staged": "^15.2.0",
    "prettier": "^3.4.0",
    "rimraf": "^6.0.0",
    "turbo": "^2.3.0",
    "typescript": "^5.7.0"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,css,md}": [
      "prettier --write"
    ]
  },
  "packageManager": "pnpm@10.28.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  }
}
